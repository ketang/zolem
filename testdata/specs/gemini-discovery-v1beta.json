{
  "resources": {
    "models": {
      "methods": {
        "generateContent": {
          "id": "models.generateContent",
          "request": {
            "$ref": "GenerateContentRequest"
          }
        },
        "streamGenerateContent": {
          "id": "models.streamGenerateContent",
          "request": {
            "$ref": "GenerateContentRequest"
          }
        }
      }
    }
  },
  "schemas": {
    "GenerateContentRequest": {
      "type": "object",
      "required": [
        "contents"
      ],
      "properties": {
        "contents": {
          "type": "array",
          "items": {
            "$ref": "Content"
          }
        },
        "generationConfig": {
          "$ref": "GenerationConfig"
        }
      }
    },
    "Content": {
      "type": "object",
      "required": [
        "parts"
      ],
      "properties": {
        "role": {
          "type": "string"
        },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "Part"
          }
        }
      }
    },
    "Part": {
      "type": "object",
      "oneOf": [
        {
          "required": [
            "text"
          ]
        },
        {
          "required": [
            "functionCall"
          ]
        },
        {
          "required": [
            "inlineData"
          ]
        }
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "functionCall": {
          "$ref": "FunctionCall"
        },
        "inlineData": {
          "$ref": "Blob"
        }
      }
    },
    "FunctionCall": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "args": {
          "type": "object"
        }
      }
    },
    "Blob": {
      "type": "object",
      "required": [
        "mimeType",
        "data"
      ],
      "properties": {
        "mimeType": {
          "type": "string"
        },
        "data": {
          "type": "string"
        }
      }
    },
    "GenerationConfig": {
      "type": "object",
      "properties": {
        "maxOutputTokens": {
          "type": "integer"
        }
      }
    }
  }
}
