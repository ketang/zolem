      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        }
      }
    },
    "GenerationConfig": {
      "type": "object",
      "properties": {
        "maxOutputTokens": {
          "type": "integer"
        }
      }
    }
  }
